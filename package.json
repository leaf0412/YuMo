{
  "name": "yumo",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "package": "CMAKE_OSX_DEPLOYMENT_TARGET=11.0 MACOSX_DEPLOYMENT_TARGET=11.0 tauri build",
    "deploy": "./scripts/deploy.sh",
    "package:deploy": "npm run package && npm run deploy",
    "release": "sh -c './scripts/bump-version.sh $VERSION && git add package.json src-tauri/tauri.conf.json src-tauri/Cargo.toml && git commit -m \"release: v$VERSION\" && git tag -a v$VERSION -m v$VERSION && git push origin main && git push origin v$VERSION'",
    "demo:record": "bash scripts/demo/record.sh",
    "demo:gif": "bash scripts/demo/postprocess.sh scripts/demo/output/raw.mp4 scripts/demo/output"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2",
    "antd": "^6.3.3",
    "i18next": "^25.8.20",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.0",
    "webdriverio": "^9.26.1"
  }
}
