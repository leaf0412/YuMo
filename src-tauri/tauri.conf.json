{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "voiceink-tauri",
  "version": "0.1.0",
  "identifier": "com.voiceink.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "voiceink-tauri",
        "width": 1024,
        "height": 768,
        "minWidth": 1024,
        "minHeight": 768
      },
      {
        "label": "recorder",
        "title": "VoiceInk Recorder",
        "url": "recorder.html",
        "width": 300,
        "height": 80,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
